# Server configuration
# All values are optional — defaults shown below.

# Address to listen on (default: :8000)
# LISTEN=:8000

# Base directory for srv/templates, srv/static, and uploads/
# Default: directory containing the executable
# BASE_DIR=/path/to/my-travels

# Google OAuth 2.0 (optional — app works without authentication)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
